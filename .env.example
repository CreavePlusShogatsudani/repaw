# ===========================================
# RePaw 環境変数設定
# ===========================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# -------------------------------------------
# microCMS
# -------------------------------------------
# サービスドメイン（xxxxx.microcms.io の xxxxx 部分）
VITE_MICROCMS_SERVICE_DOMAIN=rcm1hr6egy

# APIキー（microCMS管理画面 → サービス設定 → API-KEY）
VITE_MICROCMS_API_KEY=your-microcms-api-key

# -------------------------------------------
# Supabase
# -------------------------------------------
# プロジェクトURL（Supabase管理画面 → Settings → API）
VITE_SUPABASE_URL=https://your-project.supabase.co

# 匿名キー（公開しても安全なキー）
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------------------------------
# Stripe
# -------------------------------------------
# 公開可能キー（pk_test_ または pk_live_）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
